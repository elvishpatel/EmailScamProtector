# ============================================
# Email Scam Protector — Backend Configuration
# ============================================

# Google Gemini API Key (required for AI analysis)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=GEMINI_API
# Server port
PORT=3001

# Allowed CORS origins (comma-separated)
# For Chrome extensions, use the chrome-extension:// protocol with your extension ID
ALLOWED_ORIGINS=chrome-extension://your-extension-id-here,http://localhost:5173

# Rate limiting: max requests per window
RATE_LIMIT_MAX=100

# Rate limiting: window duration in minutes
RATE_LIMIT_WINDOW_MINUTES=15

# Environment: development | production
NODE_ENV=development
